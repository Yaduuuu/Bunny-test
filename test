# ===============================================================
# 1. VARIABLES AND DATA TYPES
# ===============================================================

# Variables store values.
a = 10            # integer
b = 12.5          # float
name = "Omkar"    # string
flag = True       # boolean


print(a, type(a))
print(b, type(b))
print(name, type(name))
print(flag, type(flag))

# Conversions
print(int(12.9))
print(float(10))
print(str(99))
print(bool(0))      # False
print(bool(5))      # True


# ===============================================================
# 2. OPERATORS
# ===============================================================

# Arithmetic
x = 10
y = 3

print(x + y)
print(x - y)
print(x * y)
print(x / y)
print(x // y)    # floor division
print(x % y)
print(x ** y)    # power

# Comparison
print(x > y)
print(x == y)
print(x != y)
# Logical
print(True and False)
print(True or False)
print(not True)

# Assignment
z = 5
z += 3
print(z)

# Membership
print(2 in [1,2,3])
print("a" in "Data")

# Identity
a1 = [1,2]
a2 = a1
print(a1 is a2)


# ===============================================================
# 3. CONTROL STRUCTURES (IF, LOOPS)
# ===============================================================

num = 7
if num > 5:
    print("Greater than 5")
elif num == 5:
    print("Equal to 5")
else:
    print("Less than 5")

# For loop
for i in range(1, 5):
    print("i =", i)

# While loop
c = 0
while c < 3:
    print("count =", c)
    c += 1

# break, continue
for i in range(1, 6):
    if i == 3:
        continue
    print("i =", i)


# ===============================================================
# 4. DEFINING FUNCTIONS
# ===============================================================

def add(a, b):
    return a + b

def greet(name="Guest"):
    return "Hello " + name

def show_all(*nums):
    for n in nums:
        print(n)

print(add(4, 6))
print(greet("Omkar"))
show_all(10, 20, 30)


# ===============================================================
# 5. BUILT-IN FUNCTIONS
# ===============================================================

lst = [10, 50, 30]

print(len(lst))
print(max(lst))
print(min(lst))
print(sum(lst))
print(sorted(lst))
print(list(reversed(lst)))

for index, value in enumerate(["a","b","c"]):
    print(index, value)

for a, b in zip([1,2], [3,4]):
    print(a, b)


