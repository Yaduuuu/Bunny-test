# ===============================================================
# 10. ARRAYS VS LISTS (NumPy)
# ===============================================================

import numpy as np

lst = [1,2,3]
arr = np.array([1,2,3])

print(lst)
print(arr)

# Lists do NOT allow vector math
# arr allows vector math:
print(arr + 5)
print(arr * 10)


# ===============================================================
# 11. ARRAY OPERATIONS (NumPy)
# ===============================================================

arr = np.array([10, 20, 30, 40])

print(arr.mean())
print(arr.sum())
print(arr.max())
print(arr.min())

print(arr[:2])
print(arr[1:4])
print(arr[::-1])

arr2 = np.array([1,1,1,1])
print(arr + arr2)
print(arr * arr2)


# ===============================================================
# 12. INDEXING, SLICING
# ===============================================================

data = np.array([5,10,15,20,25,30])

print(data[0])
print(data[-1])
print(data[2:5])
print(data[::2])
print(data[::-1])


