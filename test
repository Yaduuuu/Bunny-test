# 13. SERIES AND DATAFRAME (Pandas)
# ===============================================================

import pandas as pd

s = pd.Series([10,20,30], name="marks")
print(s)

df = pd.DataFrame({
    "name":["A","B","C"],
    "age":[21,22,23],
    "score":[88,90,85]
})
print(df)


# ===============================================================
# 14. IMPORTING / EXPORTING CSV
# ===============================================================

# Save
df.to_csv("sample_output.csv", index=False)

# Read
loaded = pd.read_csv("sample_output.csv")
print(loaded)


# ===============================================================
# 15. FILTERING, GROUPING, MERGING
# ===============================================================

df = pd.DataFrame({
    "city":["A","A","B","B","B"],
    "sales":[100,150,200,180,170]
})

# Filtering
print(df[df["sales"] > 150])

# Grouping
print(df.groupby("city")["sales"].mean())

# Merging
df1 = pd.DataFrame({"city":["A","B"], "tax":[5,10]})
df_merged = df.merge(df1, on="city")
print(df_merged)


