# ===============================================================
# 22. INTEGRATE ALL CONCEPTS (REAL DATASET)
# ===============================================================

print(iris.head())
print(iris.describe())

group_stats = iris.groupby("species")["sepal_length"].mean()
print(group_stats)

sns.boxplot(x="species", y="sepal_width", data=iris)
plt.title("Species vs Sepal Width")
plt.show()

sns.heatmap(iris.corr(), annot=True)
plt.title("Iris Correlation Heatmap")
plt.show()


